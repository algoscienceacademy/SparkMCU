# ==============================================================================
# SparkMCU .gitignore
# ==============================================================================

# --- OpenLane Run Outputs ---
# Run directories contain large intermediate files (ODB, DEF, GDS, etc.)
# that are regenerated by the flow. Keep only the config and source.
**/runs/
openlane/spark_mcu_top/runs/

# --- Simulation Outputs ---
*.vvp
*.vcd
*.fst
*.lxt
*.lxt2
*.ghw
a.out
testbench/*.vvp
testbench/*.vcd

# --- Firmware Build Artifacts ---
firmware/*.o
firmware/*.elf
firmware/*.hex
firmware/*.bin
firmware/*.map
firmware/*.lst

# --- Synthesis / Tool Intermediates ---
*.log
*.rpt
*.def
*.odb
*.sdf
*.spef
*.lib
*.lef
!openlane/spark_mcu_top/config.tcl
!openlane/spark_mcu_top/config.json
!openlane/spark_mcu_top/constraint.sdc
!openlane/spark_mcu_top/pin_order.cfg

# --- GDSII / Layout ---
*.gds
*.gds2
*.mag
*.magicrc
*.ext
*.spice
*.cir

# --- Editor / IDE ---
*.swp
*.swo
*~
.vscode/
.idea/
*.code-workspace
.project
.settings/

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Python ---
__pycache__/
*.pyc
*.pyo
.env
.venv/

# --- Miscellaneous ---
*.bak
*.orig
*.tmp
*.temp
